<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PACE</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1/dist/chartjs-plugin-annotation.min.js"></script>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-brand">
        <h1>P<span>A</span>CE</h1>
        <p>Construction Efficiency</p>
      </div>
      <nav class="sidebar-nav">
        <%
          var roleAccess = {
            procurement_skl: ['home','setup','timesheet'],
            project_engineer: ['home','planning','dashboard','timesheet','actual'],
            construction_supervisor: ['home','planning','daily-report','dashboard','timesheet','actual'],
            assistant_supervisor: ['home','planning','daily-report','dashboard','timesheet','actual'],
            contractor_user: ['home','timesheet'],
            management_viewer: ['home','dashboard','timesheet'],
            it_admin: ['home','setup','planning','daily-report','dashboard','timesheet','actual']
          };
          var allowed = user ? (roleAccess[user.role] || []) : [];
          var navItems = [
            { path: '/home', key: 'home', label: 'Home', icon: 'M3 12l9-9 9 9M5 10v10a1 1 0 001 1h3M19 10v10a1 1 0 01-1 1h-3M9 21v-6h6v6' },
            { path: '/planning', key: 'planning', label: 'Project Planning', icon: 'M9 12h6M9 16h6M8 3h8a2 2 0 0 1 2 2v14l-3-2-3 2-3-2-3 2V5a2 2 0 0 1 2-2Z' },
            { path: '/daily-report', key: 'daily-report', label: 'Daily Report', icon: 'M8 2v4M16 2v4M3 10h18M5 5h14a2 2 0 0 1 2 2v12H3V7a2 2 0 0 1 2-2Z' },
            { path: '/dashboard', key: 'dashboard', label: 'Dashboard', icon: 'M5 19V9M12 19V5M19 19v-8' },
            { path: '/timesheet', key: 'timesheet', label: 'Timesheet', icon: 'M12 8v5l3 2M21 12a9 9 0 1 1-18 0a9 9 0 0 1 18 0Z' },
            { path: '/actual', key: 'actual', label: 'Project Actual Update', icon: 'm5 13 4 4L19 7' },
            { path: '/setup', key: 'setup', label: 'Setup', icon: 'M10 4h4M12 2v4M5 13h14M5 17h8' }
          ];
        %>
        <% navItems.forEach(function(item) { if (allowed.indexOf(item.key) !== -1) { %>
          <a href="<%= item.path %>" class="nav-item <%= currentPath.indexOf(item.path) === 0 ? 'active' : '' %>">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="<%= item.icon %>" />
            </svg>
            <span><%= item.label %></span>
          </a>
        <% } }) %>
      </nav>
      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar"><%= user.full_name.charAt(0) %></div>
          <div>
            <div class="user-name"><%= user.full_name %></div>
            <div class="user-role"><%= user.role.replace(/_/g, ' ') %></div>
          </div>
        </div>
        <a href="/logout" class="logout-btn">Sign Out</a>
      </div>
    </aside>
    <main class="main-content">
      <% if (success) { %><div class="alert alert-success" id="flash-msg"><%= success %></div><% } %>
      <% if (error) { %><div class="alert alert-error" id="flash-msg"><%= error %></div><% } %>