<%
  var filterUrl = '/dashboard';
  var apiBase = '/dashboard/api/project/';
%>
<%- include('partials/header') %>
<div class="page-header">
  <h2>Dashboard</h2>
  <p>Progress index overview, PDI vs PGI analysis, and project efficiency monitoring</p>
</div>

<!-- ═══ FILTERS ═══ -->
<div class="card">
  <div class="card-header"><h3>Filters</h3></div>
  <div class="form-row">
    <div class="form-group">
      <label>Job Type</label>
      <select id="fJT" onchange="applyFilter()">
        <option value="">All</option>
        <% jobTypes.forEach(function(j) { %>
          <option value="<%= j %>" <%= fJT === j ? 'selected' : '' %>><%= j %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Sub Type 1</label>
      <select id="fST1" onchange="applyFilter()">
        <option value="">All</option>
        <% st1List.forEach(function(s) { %>
          <option value="<%= s %>" <%= fST1 === s ? 'selected' : '' %>><%= s %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Sub Type 2</label>
      <select id="fST2" onchange="applyFilter()">
        <option value="">All</option>
        <% st2List.forEach(function(s) { %>
          <option value="<%= s %>" <%= fST2 === s ? 'selected' : '' %>><%= s %></option>
        <% }); %>
      </select>
    </div>
    <div class="form-group">
      <label>Field</label>
      <select id="fField" onchange="applyFilter()">
        <option value="">All</option>
        <% fields.forEach(function(f) { %>
          <option value="<%= f %>" <%= fField === f ? 'selected' : '' %>><%= f %></option>
        <% }); %>
      </select>
    </div>
  </div>
</div>

<!-- ═══ 1. PDI vs PGI SCATTER (active jobs) ═══ -->
<div class="card" style="margin-top:16px">
  <div class="card-header"><h3>Progress Index Dashboard &mdash; PDI vs PGI (Active Jobs)</h3></div>
  <div style="padding:12px">
    <p style="font-size:12px;color:#64748b;margin:0 0 8px">X = PDI (Productivity Index) | Y = PGI (Progress Index) | Green zone: 0.8 to 1.2 for both axes</p>
    <div class="chart-container" style="min-height:400px">
      <canvas id="pdiPgiChart"></canvas>
    </div>
  </div>
</div>

<!-- ═══ 3. PROJECT DETAIL (Efficiency Dashboard) ═══ -->
<div class="card" style="margin-top:16px">
  <div class="card-header"><h3>Efficiency Dashboard &mdash; Project Detail</h3></div>
  <div style="padding:12px">
    <div class="form-group" style="max-width:400px">
      <label>Select Project</label>
      <select id="detailProjectSelect" onchange="loadProjectDetail()">
        <option value="">-- Select project --</option>
        <% allProjects.forEach(function(p) { %>
          <option value="<%= p.id %>"><%= p.project_no %> - <%= p.title %> [<%= p.status.replace(/_/g,' ') %>]</option>
        <% }); %>
      </select>
    </div>

    <div id="detailSection" style="display:none">
      <div class="summary-cards" style="margin-top:16px" id="summaryCards"></div>

      <!-- Efficiency Chart: dual Y-axis -->
      <div class="card" style="margin-top:16px">
        <div class="card-header"><h3>Efficiency Chart (Planned vs Actual)</h3></div>
        <div style="padding:4px 12px;font-size:11px;color:#64748b">Left Y = Cumulative Progress (%) | Right Y = Cumulative MH | X = Day</div>
        <div class="chart-container" style="min-height:400px"><canvas id="effMainChart"></canvas></div>
      </div>

      <div style="display:flex;gap:16px;flex-wrap:wrap;margin-top:16px">
        <div style="flex:1;min-width:300px">
          <div class="card">
            <div class="card-header"><h3>Daily Efficiency Breakdown</h3></div>
            <div class="chart-container"><canvas id="effBarChart"></canvas></div>
          </div>
        </div>
        <div style="flex:1;min-width:300px">
          <div class="card">
            <div class="card-header"><h3>Daily Manpower Working Hours</h3></div>
            <div class="chart-container"><canvas id="mpChart"></canvas></div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
var _filterUrl = '<%= filterUrl %>';
var _apiBase = '<%= apiBase %>';

function applyFilter() {
  var jt = document.getElementById('fJT').value;
  var st1 = document.getElementById('fST1').value;
  var st2 = document.getElementById('fST2').value;
  var field = document.getElementById('fField').value;
  window.location.href = _filterUrl + '?job_type=' + encodeURIComponent(jt) + '&sub_type_1=' + encodeURIComponent(st1) + '&sub_type_2=' + encodeURIComponent(st2) + '&field=' + encodeURIComponent(field);
}

// ═══ PDI vs PGI DATA ═══
var _pdiPgiData = [];
<% pdiPgiData.forEach(function(d) { %>
_pdiPgiData.push({
  name: '<%= d.name.replace(/'/g, "\\'") %>',
  status: '<%= d.status %>',
  pdi: <%= d.pdi %>,
  pgi: <%= d.pgi %>
});
<% }); %>

// ═══ PROGRESS INDEX DATA ═══
var _progressData = [];
<% progressData.forEach(function(d) { %>
_progressData.push({
  name: '<%= d.name.replace(/'/g, "\\'") %>',
  status: '<%= d.status %>',
  planDuration: <%= d.planDuration %>,
  totalManhour: <%= d.totalManhour %>,
  reportDays: <%= d.reportDays %>,
  progressIndex: <%= d.progressIndex %>
});
<% }); %>

var statusColors = {
  draft: '#9E9E9E', pending_approval: '#FFA726', approved: '#42A5F5',
  in_progress: '#66BB6A', completed: '#AB47BC'
};

// ═══ CHART 1: PDI vs PGI ═══
(function() {
  var points = _pdiPgiData.map(function(d) {
    return { x: d.pdi, y: d.pgi, label: d.name };
  });

  if (points.length === 0) {
    document.getElementById('pdiPgiChart').parentNode.innerHTML = '<div style="padding:40px;text-align:center;color:#888">No active projects with report data<\/div>';
    return;
  }

  new Chart(document.getElementById('pdiPgiChart'), {
    type: 'scatter',
    data: {
      datasets: [{
        label: 'Active Jobs',
        data: points,
        backgroundColor: '#42A5F5',
        pointRadius: 10,
        pointHoverRadius: 13
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        tooltip: {
          callbacks: {
            label: function(ctx) { return ctx.raw.label + ' | PDI=' + ctx.raw.x + ' | PGI=' + ctx.raw.y; }
          }
        },
        annotation: {
          annotations: {
            greenBox: {
              type: 'box',
              xMin: 0.8, xMax: 1.2, yMin: 0.8, yMax: 1.2,
              backgroundColor: 'rgba(76,175,80,0.12)',
              borderColor: 'rgba(76,175,80,0.5)',
              borderWidth: 2,
              label: { display: true, content: 'Green Zone', position: { x: 'end', y: 'start' }, color: '#4CAF50', font: { size: 11 } }
            },
            xLine: { type: 'line', yMin: 1, yMax: 1, borderColor: '#ccc', borderDash: [4, 4], borderWidth: 1 },
            yLine: { type: 'line', xMin: 1, xMax: 1, borderColor: '#ccc', borderDash: [4, 4], borderWidth: 1 }
          }
        }
      },
      scales: {
        x: { title: { display: true, text: 'PDI (Productivity Index)', font: { weight: 'bold' } }, min: -0.5, max: 2, ticks: { stepSize: 0.2 } },
        y: { title: { display: true, text: 'PGI (Progress Index)', font: { weight: 'bold' } }, min: -0.5, max: 2, ticks: { stepSize: 0.2 } }
      }
    }
  });
})();

// ═══ CHART 2: PROJECT DETAIL ═══
var effMainChart = null, effBarChart = null, pgiPdiTrendChart = null, mpChart = null;

async function loadProjectDetail() {
  var pid = document.getElementById('detailProjectSelect').value;
  var section = document.getElementById('detailSection');
  if (!pid) { section.style.display = 'none'; return; }
  section.style.display = 'block';

  try {
    var resp = await fetch(_apiBase + pid);
    var data = await resp.json();
    if (data.error) return;

    var proj = data.project;
    var dd = data.dailyData;
    var sum = data.summary;

    var pgiColor = (sum.pgi >= 0.8 && sum.pgi <= 1.2) ? '#22c55e' : '#ef4444';
    var pgiLabel = (sum.pgi >= 0.8 && sum.pgi <= 1.2) ? 'Good' : 'Alert';
    var pdiColor = (sum.pdi >= 0.8 && sum.pdi <= 1.2) ? '#22c55e' : '#ef4444';
    var pdiLabel = (sum.pdi >= 0.8 && sum.pdi <= 1.2) ? 'Good' : 'Alert';

    document.getElementById('summaryCards').innerHTML =
      '<div class="summary-card blue"><div class="label">Planned MH<\/div><div class="value mono">' + sum.totalPlannedMH.toFixed(1) + '<\/div><\/div>' +
      '<div class="summary-card teal"><div class="label">Actual MH<\/div><div class="value mono">' + sum.cumActualMH.toFixed(1) + '<\/div><\/div>' +
      '<div class="summary-card orange"><div class="label">Completion<\/div><div class="value mono">' + sum.completion.toFixed(1) + '%<\/div><\/div>' +
      '<div class="summary-card green"><div class="label">Report Days<\/div><div class="value mono">' + sum.reportDays + '<\/div><\/div>' +
      '<div class="summary-card"><div class="label">PGI<\/div><div class="value mono">' + sum.pgi.toFixed(3) + '<\/div><div class="sub" style="color:' + pgiColor + '">&#9679; ' + pgiLabel + '<\/div><\/div>' +
      '<div class="summary-card"><div class="label">PDI<\/div><div class="value mono">' + sum.pdi.toFixed(3) + '<\/div><div class="sub" style="color:' + pdiColor + '">&#9679; ' + pdiLabel + '<\/div><\/div>';

    var labels = dd.map(function(d) { return d.date; });

    if (effMainChart) effMainChart.destroy();
    if (effBarChart) effBarChart.destroy();
    if (pgiPdiTrendChart) pgiPdiTrendChart.destroy();
    if (mpChart) mpChart.destroy();

    if (dd.length === 0) {
      ['effMainChart','effBarChart','pgiPdiTrendChart','mpChart'].forEach(function(id) {
        document.getElementById(id).parentNode.innerHTML = '<div style="padding:30px;text-align:center;color:#888">No daily report data yet<\/div>';
      });
      return;
    }

    // Main Efficiency Chart — dual Y-axis
    effMainChart = new Chart(document.getElementById('effMainChart'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          {
            label: 'Planned Progress (%)',
            data: dd.map(function(d) { return d.plannedProgressPct; }),
            borderColor: '#2196F3', borderDash: [8, 4], fill: false, tension: 0.1, pointRadius: 2, yAxisID: 'yLeft'
          },
          {
            label: 'Actual Progress (%)',
            data: dd.map(function(d) { return d.cumProgress; }),
            borderColor: '#4CAF50', fill: false, tension: 0.3, pointRadius: 4, yAxisID: 'yLeft'
          },
          {
            label: 'Planned MH (Baseline)',
            data: dd.map(function(d) { return d.cumPlannedMH; }),
            borderColor: '#FF9800', borderDash: [8, 4], fill: false, tension: 0.1, pointRadius: 2, yAxisID: 'yRight'
          },
          {
            label: 'Actual MH',
            data: dd.map(function(d) { return d.cumActualMH; }),
            borderColor: '#F44336', fill: false, tension: 0.3, pointRadius: 4, yAxisID: 'yRight'
          }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          yLeft: { type: 'linear', position: 'left', title: { display: true, text: 'Cumulative Progress (%)' }, beginAtZero: true },
          yRight: { type: 'linear', position: 'right', title: { display: true, text: 'Cumulative MH' }, beginAtZero: true, grid: { drawOnChartArea: false } },
          x: { title: { display: true, text: 'Day' } }
        }
      }
    });

    // Efficiency Bar
    effBarChart = new Chart(document.getElementById('effBarChart'), {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [
          { label: 'Productive Hr', data: dd.map(function(d) { return d.productiveHour; }), backgroundColor: '#42A5F5' },
          { label: 'Wrench Time', data: dd.map(function(d) { return d.wrenchTime; }), backgroundColor: '#66BB6A' },
          { label: 'Downtime', data: dd.map(function(d) { return d.downtimeHour; }), backgroundColor: '#EF5350' }
        ]
      },
      options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true } } }
    });

    // Manpower
    mpChart = new Chart(document.getElementById('mpChart'), {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{ label: 'Working Hours', data: dd.map(function(d) { return d.totalMpHours; }), backgroundColor: '#FF9800' }]
      },
      options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true } } }
    });

  } catch (err) {
    console.error('Load failed:', err);
  }
}
</script>

<%- include('partials/footer') %>