<%
  var urlList = '/daily-report';
  var urlCreate = '/daily-report/create';
  var urlBack = '/daily-report?project=' + selPid;
  var urlUpdate = reportDetail ? '/daily-report/update/' + (reportDetail.report ? reportDetail.report.id : '') : '';
  var viewUrlBase = '/daily-report/view/';
  var scopeOptList = (typeof scopeOptions !== 'undefined') ? scopeOptions : [];
%>
<%- include('partials/header') %>
<div class="page-header"><h2>Daily Report</h2><p>Submit daily execution data</p></div>

<div class="filters">
  <div class="form-group"><label>Project</label>
    <%- '<form action="' + urlList + '" method="GET" id="proj-form">' %>
      <select name="project" onchange="document.getElementById('proj-form').submit()">
        <option value="">-- Select project --</option>
        <% projects.forEach(function(p) { %><option value="<%= p.id %>" <%= selPid == p.id ? 'selected' : '' %>><%= p.project_no %> - <%= p.title %></option><% }); %>
      </select>
    <%- '</form>' %>
  </div>
</div>

<% if (!selProject) { %>
  <div class="card"><div style="padding:40px;text-align:center;color:#888">No active projects.</div></div>

<% } else if (reportDetail) { %>
<% var rpt = reportDetail.report; var ed = reportDetail.editable; %>
<%- '<a href="' + urlBack + '" class="btn btn-outline btn-sm" style="margin-bottom:12px">&larr; Back</a>' %>
<div class="card">
  <div class="card-header"><h3>Report &mdash; <%= rpt.report_date %></h3><span class="badge <%= ed ? 'badge-success' : 'badge-info' %>"><%= ed ? 'Editable' : 'View Only' %></span></div>
  <div style="padding:16px">
    <% if (ed) { %><%- '<form action="' + urlUpdate + '" method="POST" id="editReportForm">' %><% } %>

    <h4>&#128203; Overall</h4>
    <div class="form-row">
      <div class="form-group"><label>Project No</label><input value="<%= selProject.project_no %>" readonly></div>
      <div class="form-group"><label>Project Name</label><input value="<%= selProject.title %>" readonly></div>
      <div class="form-group"><label>Platform</label><input value="<%= selProject.platform || '' %>" readonly></div>
      <div class="form-group"><label>Status</label><input value="<%= selProject.status.replace(/_/g,' ') %>" readonly></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>SRO Number</label><input name="sro_number" value="<%= rpt.sro_number || '' %>" <%= ed ? '' : 'readonly' %>></div>
      <div class="form-group"><label>Planned MH</label><input value="<%= selProject.total_manhour || 0 %>" readonly></div>
      <div class="form-group"><label>Accum. Actual MH</label><input value="<%= accumMH %>" readonly></div>
      <div class="form-group"><label>Weather</label><% if (ed) { %><select name="weather"><option <%= rpt.weather==='Clear'?'selected':'' %>>Clear</option><option <%= rpt.weather==='Partly Cloudy'?'selected':'' %>>Partly Cloudy</option><option <%= rpt.weather==='Cloudy'?'selected':'' %>>Cloudy</option><option <%= rpt.weather==='Rain'?'selected':'' %>>Rain</option><option <%= rpt.weather==='Storm'?'selected':'' %>>Storm</option></select><% } else { %><input value="<%= rpt.weather %>" readonly><% } %></div>
    </div>

    <h4 style="margin:16px 0 8px">&#9201; Timeline</h4>
    <div class="form-row">
      <div class="form-group"><label>Normal Working Time</label><input name="normal_working_time" value="<%= rpt.normal_working_time %>" <%= ed ? '' : 'readonly' %>></div>
      <div class="form-group"><label>LQ Departure</label><input name="lq_departure_time" value="<%= rpt.lq_departure_time %>" <%= ed ? '' : 'readonly' %>></div>
      <div class="form-group"><label>PF Arrival</label><input name="pf_arrival_time" value="<%= rpt.pf_arrival_time %>" <%= ed ? '' : 'readonly' %>></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Start Working</label><input name="start_working_time" id="ed-sw" value="<%= rpt.start_working_time %>" <%= ed ? 'onchange="calcTimelineEdit()"' : 'readonly' %>></div>
      <div class="form-group"><label>PF Departure</label><input name="pf_departure_time" id="ed-pd" value="<%= rpt.pf_departure_time %>" <%= ed ? 'onchange="calcTimelineEdit()"' : 'readonly' %>></div>
      <div class="form-group"><label>LQ Arrival</label><input name="lq_arrival_time" value="<%= rpt.lq_arrival_time %>" <%= ed ? '' : 'readonly' %>></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label>Downtime Hour</label><input type="number" step="0.5" name="downtime_hour" id="ed-dt" value="<%= rpt.downtime_hour %>" <%= ed ? 'onchange="calcTimelineEdit()"' : 'readonly' %>></div>
      <div class="form-group"><label>Productive Hour (calc)</label><input name="productive_hour" id="ed-ph" value="<%= rpt.productive_hour %>" readonly style="background:#e8f5e9"></div>
      <div class="form-group"><label>Wrench Time (calc)</label><input name="wrench_time" id="ed-wt" value="<%= rpt.wrench_time %>" readonly style="background:#e8f5e9"></div>
    </div>
    <% if (ed) { %><script>function parseTimeVal(s){if(!s)return 0;var p=s.split(':');return(parseInt(p[0])||0)+(parseInt(p[1])||0)/60;}function calcTimelineEdit(){var sw=parseTimeVal(document.getElementById('ed-sw').value);var pd=parseTimeVal(document.getElementById('ed-pd').value);var dt=parseFloat(document.getElementById('ed-dt').value)||0;var ph=Math.max(0,pd-sw-dt);document.getElementById('ed-ph').value=Math.round(ph*100)/100;document.getElementById('ed-wt').value=Math.round(ph*0.65*100)/100;}</script><% } %>

    <h4 style="margin:16px 0 8px">&#128119; Manpower</h4>
    <% if (ed) { %>
      <div id="editMpSection"></div>
      <button type="button" class="btn btn-teal btn-sm" onclick="addEditMpRow()" style="margin-bottom:8px">+ Add Manpower</button>
      <script>
      var _ep=<%- JSON.stringify(personnel) %>;var _epos=<%- JSON.stringify(positions) %>;var _eqp=<%- JSON.stringify(qps) %>;var _eco='<%= selProject.company||"" %>';var _emi=0;
      var _escopes=<%- JSON.stringify(scopeOptList) %>;
      function bO(a,k){var h='<option value="">--<\/option>';for(var j=0;j<a.length;j++)h+='<option value="'+a[j][k]+'">'+a[j][k]+'<\/option>';return h;}
      function bScopeOpts(){var h='<option value="">--<\/option>';for(var j=0;j<_escopes.length;j++)h+='<option value="'+_escopes[j]+'">'+_escopes[j]+'<\/option>';return h;}
      var _epO=bO(_ep,'person_name');var _eposO=bO(_epos,'name');var _eqpO=bO(_eqp,'name');var _esO=bScopeOpts();
      function addEditMpRow(d){d=d||{};var i=_emi++;var h='<div class="form-row" style="border-bottom:1px solid #e2e8f0;padding-bottom:8px;margin-bottom:8px">'+
        '<div class="form-group"><label>Name<\/label><select name="manpower['+i+'][person_name]" class="emp-pn" onchange="empNc(this)">'+_epO+'<\/select><input type="hidden" name="manpower['+i+'][contractor]" value="'+_eco+'"><\/div>'+
        '<div class="form-group"><label>Position<\/label><select name="manpower['+i+'][position]" class="emp-po">'+_eposO+'<\/select><\/div>'+
        '<div class="form-group"><label>Quarter PF<\/label><select name="manpower['+i+'][quarter_platform]" class="emp-qp">'+_eqpO+'<\/select><\/div>'+
        '<div class="form-group"><label>Scope<\/label><select name="manpower['+i+'][scope_ref]" class="emp-sr">'+_esO+'<\/select><\/div>'+
        '<div class="form-group"><label>Off Work<\/label><input type="number" name="manpower['+i+'][offshore_working]" value="'+(d.offshore_working||0)+'" step="0.5"><\/div>'+
        '<div class="form-group"><label>Off OT<\/label><input type="number" name="manpower['+i+'][offshore_overtime]" value="'+(d.offshore_overtime||0)+'" step="0.5"><\/div>'+
        '<div class="form-group"><label>Off SB<\/label><input type="number" name="manpower['+i+'][offshore_standby]" value="'+(d.offshore_standby||0)+'" step="0.5"><\/div>'+
        '<div class="form-group"><label>On Work<\/label><input type="number" name="manpower['+i+'][onshore_working]" value="'+(d.onshore_working||0)+'" step="0.5"><\/div>'+
        '<div class="form-group"><label>On OT<\/label><input type="number" name="manpower['+i+'][onshore_overtime]" value="'+(d.onshore_overtime||0)+'" step="0.5"><\/div>'+
        '<div class="form-group"><label>On SB<\/label><input type="number" name="manpower['+i+'][onshore_standby]" value="'+(d.onshore_standby||0)+'" step="0.5"><\/div>'+
        '<div class="form-group"><label>On SB50%<\/label><input type="number" name="manpower['+i+'][onshore_standby_50]" value="'+(d.onshore_standby_50||0)+'" step="0.5"><\/div>'+
        '<div class="form-group" style="flex:0;min-width:auto;align-self:flex-end"><button type="button" class="btn btn-outline btn-sm" style="color:red" onclick="this.closest(\'.form-row\').remove()">x<\/button><\/div><\/div>';
      document.getElementById('editMpSection').insertAdjacentHTML('beforeend',h);
      if(d.person_name){var rw=document.getElementById('editMpSection').querySelectorAll('.form-row');var r=rw[rw.length-1];r.querySelector('.emp-pn').value=d.person_name;if(d.position)r.querySelector('.emp-po').value=d.position;if(d.quarter_platform)r.querySelector('.emp-qp').value=d.quarter_platform;if(d.scope_ref)r.querySelector('.emp-sr').value=d.scope_ref;}}
      function empNc(sel){var p=_ep.find(function(x){return x.person_name===sel.value;});if(p&&p.position)sel.closest('.form-row').querySelector('.emp-po').value=p.position;}
      <% reportDetail.manpower.forEach(function(m) { %>addEditMpRow(<%- JSON.stringify(m) %>);<% }); %>
      if(_emi===0)addEditMpRow();
      </script>
    <% } else { %>
      <div class="table-wrapper"><table><thead><tr><th>Name</th><th>Position</th><th>Quarter PF</th><th>Scope</th><th>Off Work</th><th>Off OT</th><th>Off SB</th><th>On Work</th><th>On OT</th><th>On SB</th><th>On SB50%</th></tr></thead><tbody>
        <% reportDetail.manpower.forEach(function(m) { %><tr><td><%= m.person_name %></td><td><%= m.position %></td><td><%= m.quarter_platform %></td><td><%= m.scope_ref||'' %></td><td class="mono"><%= m.offshore_working %></td><td class="mono"><%= m.offshore_overtime %></td><td class="mono"><%= m.offshore_standby %></td><td class="mono"><%= m.onshore_working %></td><td class="mono"><%= m.onshore_overtime %></td><td class="mono"><%= m.onshore_standby %></td><td class="mono"><%= m.onshore_standby_50 %></td></tr><% }); %>
        <% if (!reportDetail.manpower.length) { %><tr><td colspan="11" class="text-center text-muted">No records</td></tr><% } %>
      </tbody></table></div>
    <% } %>

    <h4 style="margin:16px 0 8px">&#128295; Equipment</h4>
    <% if (ed) { %>
      <div id="editEqSection"></div>
      <button type="button" class="btn btn-teal btn-sm" onclick="addEditEqRow()" style="margin-bottom:8px">+ Add Equipment</button>
      <script>
      var _eeq=<%- JSON.stringify(eqList) %>;var _eei=0;var _eeqO=bO(_eeq,'name');
      function addEditEqRow(d){d=d||{};var i=_eei++;var h='<div class="form-row" style="border-bottom:1px solid #e2e8f0;padding-bottom:8px;margin-bottom:8px">'+
        '<div class="form-group"><label>Equipment<\/label><select name="equipment['+i+'][equipment_name]" class="eeq-nm">'+_eeqO+'<\/select><\/div>'+
        '<div class="form-group"><label>Tag<\/label><input name="equipment['+i+'][equipment_tag]" value="'+(d.equipment_tag||'')+'"><\/div>'+
        '<div class="form-group"><label>Off Work<\/label><input type="number" name="equipment['+i+'][offshore_working]" value="'+(d.offshore_working||0)+'" step="0.5"><\/div>'+
        '<div class="form-group"><label>Off SB<\/label><input type="number" name="equipment['+i+'][offshore_standby]" value="'+(d.offshore_standby||0)+'" step="0.5"><\/div>'+
        '<div class="form-group"><label>On Work<\/label><input type="number" name="equipment['+i+'][onshore_working]" value="'+(d.onshore_working||0)+'" step="0.5"><\/div>'+
        '<div class="form-group"><label>On SB<\/label><input type="number" name="equipment['+i+'][onshore_standby]" value="'+(d.onshore_standby||0)+'" step="0.5"><\/div>'+
        '<div class="form-group" style="flex:0;min-width:auto;align-self:flex-end"><button type="button" class="btn btn-outline btn-sm" style="color:red" onclick="this.closest(\'.form-row\').remove()">x<\/button><\/div><\/div>';
      document.getElementById('editEqSection').insertAdjacentHTML('beforeend',h);if(d.equipment_name){var rw=document.getElementById('editEqSection').querySelectorAll('.form-row');rw[rw.length-1].querySelector('.eeq-nm').value=d.equipment_name;}}
      <% reportDetail.equipment.forEach(function(e) { %>addEditEqRow(<%- JSON.stringify(e) %>);<% }); %>
      if(_eei===0)addEditEqRow();
      </script>
    <% } else { %>
      <div class="table-wrapper"><table><thead><tr><th>Equipment</th><th>Tag</th><th>Off Work</th><th>Off SB</th><th>On Work</th><th>On SB</th></tr></thead><tbody>
        <% reportDetail.equipment.forEach(function(e) { %><tr><td><%= e.equipment_name %></td><td><%= e.equipment_tag %></td><td class="mono"><%= e.offshore_working %></td><td class="mono"><%= e.offshore_standby %></td><td class="mono"><%= e.onshore_working %></td><td class="mono"><%= e.onshore_standby %></td></tr><% }); %>
        <% if (!reportDetail.equipment.length) { %><tr><td colspan="6" class="text-center text-muted">No records</td></tr><% } %>
      </tbody></table></div>
    <% } %>

    <h4 style="margin:16px 0 8px">&#128202; Activity</h4>
    <% if (ed) { %>
      <div id="editActSection"></div>
      <button type="button" class="btn btn-teal btn-sm" onclick="addEditActRow()" style="margin-bottom:8px">+ Add Activity</button>
      <script>
      var _eai=0;
      function addEditActRow(d){d=d||{};var i=_eai++;var py=d.progress_yesterday||0;var pt=d.progress_today||0;
      var h='<div class="form-row" style="border-bottom:1px solid #e2e8f0;padding-bottom:8px;margin-bottom:8px;align-items:flex-end">'+
        '<div class="form-group" style="flex:0;min-width:40px"><label>No<\/label><span class="mono ean">'+(i+1)+'<\/span><\/div>'+
        '<div class="form-group" style="flex:3"><label>Activity<\/label><input name="activities['+i+'][activity_name]" value="'+(d.activity_name||'')+'"><\/div>'+
        '<div class="form-group"><label>Yesterday<\/label><input name="activities['+i+'][progress_yesterday]" class="eapy" value="'+py+'" readonly style="background:#f0f0f0"><\/div>'+
        '<div class="form-group"><label>Today<\/label><input type="number" name="activities['+i+'][progress_today]" class="eapt" value="'+pt+'" step="0.1" oninput="ceaT(this)"><\/div>'+
        '<div class="form-group"><label>Total<\/label><input name="activities['+i+'][progress_total]" class="eato" value="'+(py+pt).toFixed(2)+'" readonly style="background:#f0f0f0"><\/div>'+
        '<div class="form-group" style="flex:0;min-width:auto"><button type="button" class="btn btn-outline btn-sm" style="color:red" onclick="this.closest(\'.form-row\').remove();rena()">x<\/button><\/div><\/div>';
      document.getElementById('editActSection').insertAdjacentHTML('beforeend',h);}
      function ceaT(el){var r=el.closest('.form-row');var py=parseFloat(r.querySelector('.eapy').value)||0;var pt=parseFloat(r.querySelector('.eapt').value)||0;r.querySelector('.eato').value=(py+pt).toFixed(2);}
      function rena(){var rw=document.getElementById('editActSection').querySelectorAll('.form-row');for(var j=0;j<rw.length;j++){var n=rw[j].querySelector('.ean');if(n)n.textContent=j+1;}}
      <% reportDetail.activities.forEach(function(a) { %>addEditActRow(<%- JSON.stringify(a) %>);<% }); %>
      if(_eai===0)addEditActRow();
      </script>
    <% } else { %>
      <div class="table-wrapper"><table><thead><tr><th>No</th><th>Activity</th><th>Yesterday</th><th>Today</th><th>Total</th></tr></thead><tbody>
        <% reportDetail.activities.forEach(function(a,i) { %><tr><td class="mono"><%= i+1 %></td><td><%= a.activity_name %></td><td class="mono"><%= a.progress_yesterday %></td><td class="mono"><%= a.progress_today %></td><td class="mono"><%= a.progress_total %></td></tr><% }); %>
        <% if (!reportDetail.activities.length) { %><tr><td colspan="5" class="text-center text-muted">No records</td></tr><% } %>
      </tbody></table></div>
    <% } %>

    <div class="form-group" style="margin-top:12px"><label>Remarks</label><textarea name="remarks" rows="2" <%= ed ? '' : 'readonly' %>><%= rpt.remarks || '' %></textarea></div>
    <% if (ed) { %><button type="submit" class="btn btn-primary" style="margin-top:8px;width:100%">Update Report</button><%- '</form>' %><% } %>
  </div>
</div>

<% } else { %>

<div class="card">
  <div class="card-header"><h3>Reports: <%= selProject.project_no %></h3></div>
  <div class="table-wrapper"><table>
    <thead><tr><th>ID</th><th>Date</th><th>Weather</th><th>Actual MH</th><th>Productive Hr</th><th>Wrench Time</th><th>Access</th><th>Action</th></tr></thead>
    <tbody>
      <% if (!reports.length) { %><tr><td colspan="8" class="text-center text-muted" style="padding:30px">No reports yet.</td></tr><% } %>
      <% reports.forEach(function(r) { %>
        <tr><td class="mono"><%= r.id %></td><td><%= r.report_date %></td><td><%= r.weather %></td><td class="mono"><%= r.actual_mh %></td>
        <td class="mono"><%= r.productive_hour %></td><td class="mono"><%= r.wrench_time %></td>
        <td><span class="badge <%= r.editable ? 'badge-success' : 'badge-info' %>"><%= r.editable ? 'Edit' : 'View' %></span></td>
        <td><%- '<a href="' + viewUrlBase + r.id + '" class="btn btn-outline btn-sm">' + (r.editable ? 'Edit' : 'View') + '</a>' %></td></tr>
      <% }); %>
    </tbody>
  </table></div>
</div>

<% if (todayReportExists) { %>
  <% var todayRpt = null; reports.forEach(function(r) { if (r.report_date === todayStr) todayRpt = r; }); %>
  <div class="alert alert-info" style="margin-top:16px">&#128204; Today's report exists.
    <% if (todayRpt) { %><%- '<a href="' + viewUrlBase + todayRpt.id + '" class="btn btn-primary btn-sm" style="margin-left:8px">' + (todayRpt.editable ? 'Edit' : 'View') + '</a>' %><% } %>
  </div>
<% } else { %>

<div class="card" style="margin-top:16px">
  <div class="card-header"><h3>+ New Report</h3></div>
  <div style="padding:16px">
    <%- '<form action="' + urlCreate + '" method="POST" id="newReportForm">' %>
      <input type="hidden" name="project_id" value="<%= selPid %>">
      <div class="alert alert-info">Report Date: <strong><%= todayStr %></strong></div>

      <h4>&#128203; Overall</h4>
      <div class="form-row">
        <div class="form-group"><label>Project No</label><input value="<%= selProject.project_no %>" readonly></div>
        <div class="form-group"><label>Project Name</label><input value="<%= selProject.title %>" readonly></div>
        <div class="form-group"><label>Platform</label><input value="<%= selProject.platform || '' %>" readonly></div>
        <div class="form-group"><label>Status</label><input value="<%= selProject.status.replace(/_/g,' ') %>" readonly></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>SRO Number</label><input name="sro_number"></div>
        <div class="form-group"><label>Planned MH</label><input value="<%= selProject.total_manhour || 0 %>" readonly></div>
        <div class="form-group"><label>Accum. Actual MH</label><input value="<%= accumMH %>" readonly></div>
        <div class="form-group"><label>Weather</label><select name="weather"><option>Clear</option><option>Partly Cloudy</option><option>Cloudy</option><option>Rain</option><option>Storm</option></select></div>
      </div>

      <h4 style="margin:16px 0 8px">&#9201; Timeline</h4>
      <div class="form-row">
        <div class="form-group"><label>Normal Working Time</label><input name="normal_working_time" id="tl-nwt" value="7:00"></div>
        <div class="form-group"><label>LQ Departure</label><input name="lq_departure_time" value="06:30"></div>
        <div class="form-group"><label>PF Arrival</label><input name="pf_arrival_time" value="07:00"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Start Working</label><input name="start_working_time" id="tl-sw" value="07:30" onchange="calcTL()"></div>
        <div class="form-group"><label>PF Departure</label><input name="pf_departure_time" id="tl-pd" value="17:30" onchange="calcTL()"></div>
        <div class="form-group"><label>LQ Arrival</label><input name="lq_arrival_time" value="18:00"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Downtime Hour</label><input type="number" name="downtime_hour" id="tl-dt" value="0" step="0.5" onchange="calcTL()"></div>
        <div class="form-group"><label>Productive Hour (calc)</label><input name="productive_hour" id="tl-ph" value="0" readonly style="background:#e8f5e9"></div>
        <div class="form-group"><label>Wrench Time (calc)</label><input name="wrench_time" id="tl-wt" value="0" readonly style="background:#e8f5e9"></div>
      </div>

      <h4 style="margin:16px 0 8px">&#128119; Manpower <button type="button" class="btn btn-teal btn-sm" onclick="addMpRow()">+ Add</button></h4>
      <div class="table-wrapper"><table>
        <thead><tr><th>Name</th><th>Position</th><th>Quarter PF</th><th>Scope</th><th>Off Work</th><th>Off OT</th><th>Off SB</th><th>On Work</th><th>On OT</th><th>On SB</th><th>On SB50%</th><th></th></tr></thead>
        <tbody id="mpBody"></tbody>
      </table></div>

      <h4 style="margin:16px 0 8px">&#128295; Equipment <button type="button" class="btn btn-teal btn-sm" onclick="addEqRow()">+ Add</button></h4>
      <div class="table-wrapper"><table>
        <thead><tr><th>Equipment</th><th>Tag</th><th>Off Work</th><th>Off SB</th><th>On Work</th><th>On SB</th><th></th></tr></thead>
        <tbody id="eqBody"></tbody>
      </table></div>

      <h4 style="margin:16px 0 8px">&#128202; Activity <button type="button" class="btn btn-teal btn-sm" onclick="addActRow()">+ Add</button></h4>
      <div class="table-wrapper"><table>
        <thead><tr><th style="width:40px">No</th><th>Activity Name</th><th>Yesterday</th><th>Today</th><th>Total</th><th></th></tr></thead>
        <tbody id="actBody"></tbody>
      </table></div>

      <div class="form-group" style="margin-top:12px"><label>Remarks</label><textarea name="remarks" rows="2"></textarea></div>
      <button type="submit" class="btn btn-primary" style="width:100%;margin-top:12px">Save Daily Report</button>
    <%- '</form>' %>
  </div>
</div>

<script>
var _sd={personnel:<%- JSON.stringify(personnel) %>,positions:<%- JSON.stringify(positions) %>,qps:<%- JSON.stringify(qps) %>,eqList:<%- JSON.stringify(eqList) %>,selPid:<%= selPid %>,company:'<%= selProject.company||"" %>',scopes:<%- JSON.stringify(scopeOptList) %>};
function bOp(a,k){var h='<option value="">--<\/option>';for(var i=0;i<a.length;i++)h+='<option value="'+a[i][k]+'">'+a[i][k]+'<\/option>';return h;}
function bSO(){var h='<option value="">--<\/option>';for(var i=0;i<_sd.scopes.length;i++)h+='<option value="'+_sd.scopes[i]+'">'+_sd.scopes[i]+'<\/option>';return h;}
var personOpts=bOp(_sd.personnel,'person_name');var posOpts=bOp(_sd.positions,'name');var qpOpts=bOp(_sd.qps,'name');var eqOpts=bOp(_sd.eqList,'name');var scopeOpts=bSO();
var mi=0,ei=0,ai=0;
function pT(s){if(!s)return 0;var p=s.split(':');return(parseInt(p[0])||0)+(parseInt(p[1])||0)/60;}
function calcTL(){var sw=pT(document.getElementById('tl-sw').value);var pd=pT(document.getElementById('tl-pd').value);var dt=parseFloat(document.getElementById('tl-dt').value)||0;var ph=Math.max(0,pd-sw-dt);document.getElementById('tl-ph').value=Math.round(ph*100)/100;document.getElementById('tl-wt').value=Math.round(ph*0.65*100)/100;}

function addMpRow(d){d=d||{};var i=mi++;document.getElementById('mpBody').insertAdjacentHTML('beforeend',
  '<tr><td><select name="manpower['+i+'][person_name]" class="mp-pn" onchange="mpNc(this)">'+personOpts+'<\/select><input type="hidden" name="manpower['+i+'][contractor]" value="'+_sd.company+'"><\/td>'+
  '<td><select name="manpower['+i+'][position]" class="mp-po">'+posOpts+'<\/select><\/td>'+
  '<td><select name="manpower['+i+'][quarter_platform]" class="mp-qp">'+qpOpts+'<\/select><\/td>'+
  '<td><select name="manpower['+i+'][scope_ref]" class="mp-sr">'+scopeOpts+'<\/select><\/td>'+
  '<td><input type="number" name="manpower['+i+'][offshore_working]" value="'+(d.offshore_working||0)+'" step="0.5" style="width:55px"><\/td>'+
  '<td><input type="number" name="manpower['+i+'][offshore_overtime]" value="'+(d.offshore_overtime||0)+'" step="0.5" style="width:55px"><\/td>'+
  '<td><input type="number" name="manpower['+i+'][offshore_standby]" value="'+(d.offshore_standby||0)+'" step="0.5" style="width:55px"><\/td>'+
  '<td><input type="number" name="manpower['+i+'][onshore_working]" value="'+(d.onshore_working||0)+'" step="0.5" style="width:55px"><\/td>'+
  '<td><input type="number" name="manpower['+i+'][onshore_overtime]" value="'+(d.onshore_overtime||0)+'" step="0.5" style="width:55px"><\/td>'+
  '<td><input type="number" name="manpower['+i+'][onshore_standby]" value="'+(d.onshore_standby||0)+'" step="0.5" style="width:55px"><\/td>'+
  '<td><input type="number" name="manpower['+i+'][onshore_standby_50]" value="'+(d.onshore_standby_50||0)+'" step="0.5" style="width:55px"><\/td>'+
  '<td><button type="button" class="btn btn-outline btn-sm" style="color:red" onclick="this.closest(\'tr\').remove()">x<\/button><\/td><\/tr>');
  if(d.person_name){var r=document.getElementById('mpBody').lastElementChild;r.querySelector('.mp-pn').value=d.person_name;if(d.position)r.querySelector('.mp-po').value=d.position;if(d.quarter_platform)r.querySelector('.mp-qp').value=d.quarter_platform;if(d.scope_ref)r.querySelector('.mp-sr').value=d.scope_ref;}}
function mpNc(sel){var p=_sd.personnel.find(function(x){return x.person_name===sel.value;});if(p&&p.position)sel.closest('tr').querySelector('.mp-po').value=p.position;}

function addEqRow(d){d=d||{};var i=ei++;document.getElementById('eqBody').insertAdjacentHTML('beforeend',
  '<tr><td><select name="equipment['+i+'][equipment_name]" class="eq-nm">'+eqOpts+'<\/select><\/td>'+
  '<td><input type="text" name="equipment['+i+'][equipment_tag]" value="'+(d.equipment_tag||'')+'" style="width:100px"><\/td>'+
  '<td><input type="number" name="equipment['+i+'][offshore_working]" value="'+(d.offshore_working||0)+'" step="0.5" style="width:60px"><\/td>'+
  '<td><input type="number" name="equipment['+i+'][offshore_standby]" value="'+(d.offshore_standby||0)+'" step="0.5" style="width:60px"><\/td>'+
  '<td><input type="number" name="equipment['+i+'][onshore_working]" value="'+(d.onshore_working||0)+'" step="0.5" style="width:60px"><\/td>'+
  '<td><input type="number" name="equipment['+i+'][onshore_standby]" value="'+(d.onshore_standby||0)+'" step="0.5" style="width:60px"><\/td>'+
  '<td><button type="button" class="btn btn-outline btn-sm" style="color:red" onclick="this.closest(\'tr\').remove()">x<\/button><\/td><\/tr>');
  if(d.equipment_name)document.getElementById('eqBody').lastElementChild.querySelector('.eq-nm').value=d.equipment_name;}

function addActRow(d){d=d||{};var i=ai++;var py=d.progress_yesterday||0;var pt=d.progress_today||0;document.getElementById('actBody').insertAdjacentHTML('beforeend',
  '<tr><td class="mono act-no">'+(i+1)+'<\/td>'+
  '<td><input type="text" name="activities['+i+'][activity_name]" value="'+(d.activity_name||'')+'" style="width:200px"><\/td>'+
  '<td><input type="number" name="activities['+i+'][progress_yesterday]" class="act-py" value="'+py+'" readonly style="width:80px;background:#f0f0f0"><\/td>'+
  '<td><input type="number" name="activities['+i+'][progress_today]" class="act-pt" value="'+pt+'" step="0.1" style="width:80px" oninput="cAT(this)"><\/td>'+
  '<td><input type="number" name="activities['+i+'][progress_total]" class="act-tot" value="'+(py+pt).toFixed(2)+'" readonly style="width:80px;background:#f0f0f0"><\/td>'+
  '<td><button type="button" class="btn btn-outline btn-sm" style="color:red" onclick="this.closest(\'tr\').remove();rn()">x<\/button><\/td><\/tr>');}
function cAT(el){var tr=el.closest('tr');var py=parseFloat(tr.querySelector('.act-py').value)||0;var pt=parseFloat(tr.querySelector('.act-pt').value)||0;tr.querySelector('.act-tot').value=(py+pt).toFixed(2);}
function rn(){var rows=document.querySelectorAll('#actBody tr');for(var i=0;i<rows.length;i++)rows[i].querySelector('.act-no').textContent=i+1;}

calcTL();
(async function(){try{var resp=await fetch('/daily-report/api/yesterday/'+_sd.selPid);var data=await resp.json();if(data.found){var f=document.getElementById('newReportForm');var r=data.report;['normal_working_time','lq_departure_time','pf_arrival_time','start_working_time','pf_departure_time','lq_arrival_time'].forEach(function(k){if(r[k]){var el=f.querySelector('[name="'+k+'"]');if(el)el.value=r[k];}});data.manpower.forEach(function(m){addMpRow(m);});data.equipment.forEach(function(e){addEqRow(e);});data.activities.forEach(function(a){addActRow({activity_name:a.activity_name,progress_yesterday:data.accum[a.activity_name]||0,progress_today:0});});calcTL();}if(!data.found||!data.manpower||data.manpower.length===0)addMpRow();if(!data.found||!data.equipment||data.equipment.length===0)addEqRow();if(!data.found||!data.activities||data.activities.length===0)addActRow();}catch(e){addMpRow();addEqRow();addActRow();}})();
</script>
<% } %>
<% } %>
<%- include('partials/footer') %>