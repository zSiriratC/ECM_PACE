<%- include('partials/header') %>
<div class="page-header"><h2>Home</h2><p>Current tasks and workflow</p></div>

<div class="card">
  <div class="card-header"><h3>Workflow</h3></div>
  <div class="workflow-steps">
    <div class="workflow-step"><div class="step-num">1</div><div class="step-role">Construction Engineer</div><div class="step-action">Prepare Planning</div></div>
    <div class="workflow-step"><div class="step-num">2</div><div class="step-role">Construction Supervisor</div><div class="step-action">Approve Planning</div></div>
    <div class="workflow-step"><div class="step-num">3</div><div class="step-role">Asst Supervisor</div><div class="step-action">Daily Report</div></div>
    <div class="workflow-step"><div class="step-num">4</div><div class="step-role">Asst Supervisor</div><div class="step-action">Update Actual Qty</div></div>
  </div>
</div>

<div class="summary-cards">
  <div class="summary-card blue"><div class="label">Draft</div><div class="value mono"><%= counts.draft %></div></div>
  <div class="summary-card orange"><div class="label">Pending</div><div class="value mono"><%= counts.pending_approval %></div></div>
  <div class="summary-card teal"><div class="label">Approved</div><div class="value mono"><%= counts.approved %></div></div>
  <div class="summary-card green"><div class="label">In Progress</div><div class="value mono"><%= counts.in_progress %></div></div>
  <div class="summary-card"><div class="label">Completed</div><div class="value mono"><%= counts.completed %></div></div>
</div>

<div class="card" style="margin-top:20px">
  <div class="card-header"><h3>My Tasks &mdash; <%= taskDesc %></h3></div>
  <div class="table-wrapper">
    <table>
      <thead><tr><th>ID</th><th>Project</th><th>Title</th><th>Job Type</th><th>Status</th><th>Action</th></tr></thead>
      <tbody>
        <% if (!myTasks.length) { %><tr><td colspan="6" style="text-align:center;padding:30px;color:#888">No tasks</td></tr><% } %>
        <% myTasks.forEach(function(p) { %>
          <tr>
            <td class="mono"><%= p.id %></td>
            <td class="mono"><%= p.project_no %></td>
            <td><%= p.title %></td>
            <td><%= p.job_type || '-' %></td>
            <td><span class="badge badge-info"><%= p.status.replace(/_/g,' ') %></span></td>
            <td>
              <% if (p.status === 'in_progress') { %>
                <a href="/daily-report?project=<%= p.id %>" class="btn btn-outline btn-sm">Daily Report</a>
              <% } else if (p.status === 'completed') { %>
                <a href="/actual?project=<%= p.id %>" class="btn btn-outline btn-sm">Actual Update</a>
              <% } else { %>
                <a href="/planning/<%= p.id %>" class="btn btn-outline btn-sm">Project Planning</a>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (completed.length && ['assistant_supervisor','construction_supervisor','it_admin'].indexOf(user.role) !== -1) { %>
<div class="card" style="margin-top:16px">
  <div class="card-header"><h3>Completed &mdash; Update Actual</h3></div>
  <div class="table-wrapper"><table>
    <thead><tr><th>Project</th><th>Action</th></tr></thead>
    <tbody>
      <% completed.forEach(function(p) { %>
        <tr><td><%= p.project_no %> - <%= p.title %></td>
        <td><a href="/actual?project=<%= p.id %>" class="btn btn-success btn-sm">Update</a></td></tr>
      <% }) %>
    </tbody>
  </table></div>
</div>
<% } %>

<% if (recent.length) { %>
<div class="card" style="margin-top:16px">
  <div class="card-header"><h3>Recent Reports</h3></div>
  <div class="table-wrapper"><table>
    <thead><tr><th>Date</th><th>Project</th><th>Productive Hr</th><th>By</th></tr></thead>
    <tbody>
      <% recent.forEach(function(r) { %>
        <tr><td><%= r.report_date %></td><td><%= r.project_no %></td><td class="mono"><%= r.productive_hour %></td><td><%= r.created_by %></td></tr>
      <% }) %>
    </tbody>
  </table></div>
</div>
<% } %>

<%- include('partials/footer') %>