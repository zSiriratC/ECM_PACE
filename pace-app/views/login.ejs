<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PACE Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-body">
  <div class="login-card">
    <div class="login-brand">
      <h1>P<span>A</span>CE</h1>
      <p>Intelligence Construction Application</p>
    </div>
    <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <form action="/login" method="POST">
      <div class="form-group"><label>Username</label><input name="username" required autofocus></div>
      <div class="form-group"><label>Password</label><input name="password" type="password" required></div>
      <button class="btn btn-primary" style="width:100%;margin-top:12px">Sign In</button>
    </form>
    <div style="margin-top:16px;font-size:12px;color:#666">
      <b>admin</b> / <b>engineer</b> / <b>supervisor</b> / <b>asst_sup</b><br>Password: password123
    </div>
  </div>
</body>
</html>