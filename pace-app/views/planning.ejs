<%- include('partials/header') %>
<div class="page-header"><h2>Project Planning</h2><p>Create and manage job planning baseline</p></div>

<% if (mode === 'list') { %>
<!-- ═══ LIST ═══ -->
<div class="card">
  <div class="card-header" style="cursor:pointer" onclick="document.getElementById('cs').classList.toggle('hidden')"><h3>+ Create New Project</h3></div>
  <div id="cs" class="hidden" style="padding:16px">
    <form action="/planning/create" method="POST">
      <div class="form-row">
        <div class="form-group"><label>Project No *</label><input name="project_no" required></div>
        <div class="form-group"><label>Title</label><input name="title"></div>
        <div class="form-group"><label>Field</label><input name="field"></div>
        <div class="form-group"><label>Platform</label><input name="platform"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Job Type</label><select name="job_type" id="sel_jt" onchange="loadST1()"><option value="">--</option><% jobTypes.forEach(function(j){ %><option value="<%=j.name%>"><%=j.name%></option><% }); %></select></div>
        <div class="form-group"><label>Sub Type 1</label><select name="sub_type_1" id="sel_st1" onchange="loadST2()"><option value="">--</option></select></div>
        <div class="form-group"><label>Sub Type 2</label><select name="sub_type_2" id="sel_st2"><option value="">--</option></select></div>
        <div class="form-group"><label>Company</label><select name="company"><option value="">--</option><% companies.forEach(function(c){ %><option value="<%=c.name%>"><%=c.name%></option><% }); %></select></div>
      </div>
      <button type="submit" class="btn btn-primary">Create Project</button>
    </form>
  </div>
</div>
<script>
async function loadST1(){var v=document.getElementById('sel_jt').value,s=document.getElementById('sel_st1');s.innerHTML='<option value="">--</option>';document.getElementById('sel_st2').innerHTML='<option value="">--</option>';if(!v)return;(await(await fetch('/planning/api/subtypes1/'+encodeURIComponent(v))).json()).forEach(function(i){s.innerHTML+='<option value="'+i.name+'">'+i.name+'</option>';});}
async function loadST2(){var v=document.getElementById('sel_st1').value,s=document.getElementById('sel_st2');s.innerHTML='<option value="">--</option>';if(!v)return;(await(await fetch('/planning/api/subtypes2/'+encodeURIComponent(v))).json()).forEach(function(i){s.innerHTML+='<option value="'+i.name+'">'+i.name+'</option>';});}
</script>
<div class="summary-cards" style="margin-top:16px">
  <% var sl=['draft','pending_approval','approved','in_progress','completed'],lb=['Draft','Pending','Approved','In Progress','Completed'],cl=['#FF6B6B','#FFA726','#42A5F5','#66BB6A','#AB47BC']; %>
  <% sl.forEach(function(s,i){ %><div class="summary-card" style="border-left:4px solid <%=cl[i]%>"><div class="label"><%=lb[i]%></div><div class="value mono"><%=counts[s]||0%></div></div><% }); %>
</div>
<div class="card" style="margin-top:16px">
  <div class="card-header"><h3>Projects</h3></div>
  <div class="table-wrapper"><table>
    <thead><tr><th>ID</th><th>Project No</th><th>Title</th><th>Job Type</th><th>Company</th><th>Status</th><th>Action</th></tr></thead>
    <tbody>
      <% if(!projects.length){ %><tr><td colspan="7" class="text-center text-muted" style="padding:30px">No projects</td></tr><% } %>
      <% projects.forEach(function(p){ %>
        <tr><td class="mono"><%=p.id%></td><td class="mono"><%=p.project_no%></td><td><%=p.title%></td><td><%=p.job_type||'-'%></td><td><%=p.company||'-'%></td>
        <td><span class="badge badge-info"><%=p.status.replace(/_/g,' ')%></span></td>
        <td><a href="/planning/<%=p.id%>" class="btn btn-outline btn-sm">Detail</a></td></tr>
      <% }); %>
    </tbody>
  </table></div>
</div>


<% } else if (mode === 'summary') { %>
<!-- ═══ SUMMARY ═══ -->
<a href="/planning" class="btn btn-outline btn-sm" style="margin-bottom:12px">← Back to Project List</a>

<div class="card">
  <div class="card-header"><h3><%=project.project_no%> — <%=project.title%></h3></div>
  <div class="form-row" style="padding:12px">
    <div class="form-group"><label>Field</label><input value="<%=project.field||''%>" readonly></div>
    <div class="form-group"><label>Platform</label><input value="<%=project.platform||''%>" readonly></div>
    <div class="form-group"><label>Job Type</label><input value="<%=project.job_type||''%>" readonly></div>
    <div class="form-group"><label>Company</label><input value="<%=project.company||''%>" readonly></div>
    <div class="form-group"><label>Status</label><input value="<%=project.status.replace(/_/g,' ')%>" readonly></div>
  </div>
</div>

<!-- Status Actions + Delete -->
<div class="flex gap-2" style="margin-bottom:16px">
  <% if(canSubmit){ %>
    <form action="/planning/<%=project.id%>/status" method="POST" style="display:inline"><input type="hidden" name="action" value="submit"><button class="btn btn-primary">Submit for Approval</button></form>
  <% } %>
  <% if(canApprove){ %>
    <form action="/planning/<%=project.id%>/status" method="POST" style="display:inline"><input type="hidden" name="action" value="approve"><button class="btn btn-success">Approve</button></form>
  <% } %>
  <% if(canReject){ %>
    <form action="/planning/<%=project.id%>/status" method="POST" style="display:inline"><input type="hidden" name="action" value="reject"><button class="btn btn-outline" style="color:red;border-color:red">Reject</button></form>
  <% } %>
  <% if(canStart){ %>
    <form action="/planning/<%=project.id%>/status" method="POST" style="display:inline"><input type="hidden" name="action" value="start"><button class="btn btn-teal">Start</button></form>
  <% } %>
  <% if(canComplete){ %>
    <form action="/planning/<%=project.id%>/status" method="POST" style="display:inline"><input type="hidden" name="action" value="complete"><button class="btn btn-success">Complete</button></form>
  <% } %>
  <% if(editable){ %>
    <form action="/planning/<%=project.id%>/delete" method="POST" style="display:inline" onsubmit="return confirm('Are you sure you want to DELETE this project? This cannot be undone.')">
      <button class="btn btn-outline btn-sm" style="color:red;border-color:red">Delete Project</button>
    </form>
  <% } %>
</div>

<!-- Scope Table -->
<div class="card">
  <div class="card-header"><h3>Scope</h3></div>
  <div class="table-wrapper"><table>
    <thead><tr><th style="width:60px">No.</th><th>Structure</th><th>Basis</th><th style="text-align:right">SUM MH</th><th>Unit</th><th style="width:80px">Action</th></tr></thead>
    <tbody>
      <% var pctVal = inputTotal * 0.05; %>
      <% SCOPE.forEach(function(s) { %>
        <% if (s.type === 'header') { %>
          <tr style="background:#e2e8f0;font-weight:700">
            <td class="mono"><%= s.no %></td><td><%= s.name %></td><td></td><td></td><td></td><td></td>
          </tr>
        <% } else if (s.type === 'percent') { %>
          <tr style="background:#f8fafc">
            <td class="mono"><strong><%= s.no %></strong></td><td><strong><%= s.name %></strong></td>
            <td><%= s.basis %></td><td class="mono" style="text-align:right"><%= pctVal > 0 ? pctVal.toFixed(2) : '-' %></td><td>MH</td><td></td>
          </tr>
        <% } else { %>
          <% var mhVal = refSums[s.no] || 0; %>
          <tr>
            <td class="mono"><%= s.no %></td>
            <td style="padding-left:<%= s.no.indexOf('.') !== -1 ? '30px' : '12px' %>"><%= s.name %></td>
            <td><%= s.basis %></td>
            <td class="mono" style="text-align:right"><%= mhVal > 0 ? mhVal.toFixed(2) : '-' %></td>
            <td>MH</td>
            <td><a href="/planning/<%= project.id %>/detail/<%= encodeURIComponent(s.no) %>" class="btn btn-outline btn-sm">Detail</a></td>
          </tr>
        <% } %>
      <% }); %>
    </tbody>
  </table></div>
</div>

<!-- Parameters — auto-save on change -->
<%
  var totalProdMH = inputTotal + (pctVal * 3);
  var contingencyPct = project.contingency || 10;
  var totalWithCont = totalProdMH * (1 + contingencyPct / 100);
  var prodTime = project.productive_time || 8;
  var mpCount = project.manpower_count || 1;
  var estDur = (prodTime * mpCount) > 0 ? totalWithCont / (prodTime * mpCount) : 0;
  var totalMD = Math.ceil(estDur);
%>
<div class="card" style="margin-top:16px">
  <div class="card-header"><h3>Project Parameters & Calculations</h3></div>
  <div style="padding:12px">
    <% if (editable) { %>
      <div class="form-row">
        <div class="form-group"><label>Contingency (%)</label>
          <input type="number" id="p-cont" value="<%=project.contingency||10%>" step="1" min="0" max="100" onchange="autoSaveParams()">
        </div>
        <div class="form-group"><label>Productive Time (hrs/day)</label>
          <input type="number" id="p-pt" value="<%=project.productive_time||8%>" step="0.1" onchange="autoSaveParams()">
        </div>
        <div class="form-group"><label>Man-Power (POB/Day)</label>
          <input type="number" id="p-mp" value="<%=project.manpower_count||5%>" step="1" min="1" onchange="autoSaveParams()">
        </div>
        <div class="form-group"><label>Plan to Start</label>
          <input type="date" id="p-ps" value="<%=project.plan_start||''%>" onchange="autoSaveParams()">
        </div>
      </div>
      <div id="save-status" style="font-size:12px;color:#22c55e;margin-bottom:8px"></div>
      <script>
      var _saveTimer = null;
      function autoSaveParams() {
        clearTimeout(_saveTimer);
        _saveTimer = setTimeout(function() {
          document.getElementById('save-status').textContent = 'Saving...';
          fetch('/planning/<%= project.id %>/params-auto', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contingency: document.getElementById('p-cont').value,
              productive_time: document.getElementById('p-pt').value,
              manpower_count: document.getElementById('p-mp').value,
              plan_start: document.getElementById('p-ps').value
            })
          }).then(function(r){ return r.json(); }).then(function(d) {
            if (d.success) {
              document.getElementById('save-status').textContent = 'Saved ✓';
              // Reload to update calculated values
              setTimeout(function() { location.reload(); }, 500);
            }
          });
        }, 600);
      }
      </script>
    <% } else { %>
      <div class="form-row">
        <div class="form-group"><label>Contingency</label><input value="<%=project.contingency%>%" readonly></div>
        <div class="form-group"><label>Productive Time</label><input value="<%=project.productive_time%> hrs/day" readonly></div>
        <div class="form-group"><label>Man-Power</label><input value="<%=project.manpower_count%> POBs" readonly></div>
        <div class="form-group"><label>Plan Start</label><input value="<%=project.plan_start||'N/A'%>" readonly></div>
      </div>
    <% } %>

    <div class="table-wrapper" style="margin-top:16px"><table>
      <tbody>
        <tr><td><strong>Total Productive MH</strong></td><td>Calc</td><td class="mono" style="text-align:right"><%= totalProdMH.toFixed(2) %></td><td>MH</td></tr>
        <tr><td><strong>+ Contingency</strong></td><td><%= contingencyPct %>%</td><td class="mono" style="text-align:right"><%= totalWithCont.toFixed(2) %></td><td>MH</td></tr>
        <tr><td><strong>Productive Time</strong></td><td>Input</td><td class="mono" style="text-align:right"><%= prodTime %></td><td>Hrs/day</td></tr>
        <tr><td><strong>Man-Power (POB/Day)</strong></td><td>Input</td><td class="mono" style="text-align:right"><%= mpCount %></td><td>POBs</td></tr>
        <tr><td><strong>Estimate Duration</strong></td><td>Calc</td><td class="mono" style="text-align:right"><%= estDur.toFixed(1) %></td><td>Days</td></tr>
        <tr><td><strong>Total MD</strong></td><td>Calc</td><td class="mono" style="text-align:right"><%= totalMD %></td><td>MD</td></tr>
        <tr style="background:#e8f5e9"><td><strong>Total MH (incl. contingency)</strong></td><td>Calc</td><td class="mono" style="text-align:right"><strong><%= totalWithCont.toFixed(2) %></strong></td><td>MH</td></tr>
        <tr><td><strong>Plan to Start</strong></td><td>Input</td><td class="mono" style="text-align:right"><%= project.plan_start || 'N/A' %></td><td></td></tr>
        <tr><td><strong>Plan to Finish</strong></td><td>Calc</td><td class="mono" style="text-align:right"><%= project.plan_end || 'N/A' %></td><td></td></tr>
      </tbody>
    </table></div>
  </div>
</div>


<% } else if (mode === 'detail') { %>
<!-- ═══ DETAIL ═══ -->
<a href="/planning/<%= project.id %>" class="btn btn-outline btn-sm" style="margin-bottom:12px">← Back to Summary</a>

<div class="card">
  <div class="card-header">
    <h3><%= project.project_no %> — <%= scopeRef %> <%= scopeLine ? scopeLine.name : '' %></h3>
  </div>
  <% if (items.length === 0) { %>
    <div style="padding:30px;text-align:center;color:#888">No items yet. Add one below.</div>
  <% } else { %>
  <div class="table-wrapper"><table>
    <thead><tr><th>Work Item</th><th>Qty</th><th>Unit</th><th>Difficulty</th><th>Std MH/Unit</th><th>Planned MH</th><th>Remark</th><% if(editable){ %><th></th><% } %></tr></thead>
    <tbody id="detail-body">
      <% items.forEach(function(it) { %>
        <tr data-id="<%= it.id %>" data-mh="<%= it.std_mh_per_unit %>">
          <td><%= it.work_item %></td>
          <% if (editable) { %>
            <td><input class="d-qty" type="number" step="0.1" value="<%= it.quantity %>" style="width:70px" onchange="autoSaveItem(this)"></td>
          <% } else { %>
            <td class="mono"><%= it.quantity %></td>
          <% } %>
          <td><%= it.unit %></td>
          <% if (editable) { %>
            <td><select class="d-diff" onchange="autoSaveItem(this)">
              <option <%= it.difficulty==='Low'?'selected':'' %>>Low</option>
              <option <%= it.difficulty==='Normal'||it.difficulty==='Medium'?'selected':'' %>>Normal</option>
              <option <%= it.difficulty==='Difficult'||it.difficulty==='High'?'selected':'' %>>Difficult</option>
              <option <%= it.difficulty==='N/A'?'selected':'' %>>N/A</option>
            </select></td>
          <% } else { %>
            <td><%= it.difficulty %></td>
          <% } %>
          <td class="mono"><%= it.std_mh_per_unit %></td>
          <td class="mono d-planned"><%= (it.planned_mh || 0).toFixed(2) %></td>
          <% if (editable) { %>
            <td><input class="d-rmk" value="<%= it.remark || '' %>" style="width:100px" onchange="autoSaveItem(this)"></td>
            <td>
              <form action="/planning/<%= project.id %>/delete-item/<%= it.id %>" method="POST" style="display:inline" onsubmit="return confirm('Delete?')">
                <button class="btn btn-outline btn-sm" style="color:red">✕</button>
              </form>
            </td>
          <% } else { %>
            <td><%= it.remark || '' %></td>
          <% } %>
        </tr>
      <% }); %>
    </tbody>
  </table></div>
  <% } %>
</div>

<% if (editable) { %>
<script>
var _itemTimer = null;
function autoSaveItem(el) {
  var tr = el.closest('tr');
  var qty = parseFloat(tr.querySelector('.d-qty').value) || 0;
  var mh = parseFloat(tr.dataset.mh) || 0;
  tr.querySelector('.d-planned').textContent = (qty * mh).toFixed(2);

  clearTimeout(_itemTimer);
  _itemTimer = setTimeout(function() {
    fetch('/planning/<%= project.id %>/item-auto', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id: tr.dataset.id,
        quantity: tr.querySelector('.d-qty').value,
        difficulty: tr.querySelector('.d-diff').value,
        std_mh_per_unit: tr.dataset.mh,
        remark: tr.querySelector('.d-rmk') ? tr.querySelector('.d-rmk').value : ''
      })
    }).then(function(r){ return r.json(); }).then(function(d) {
      if (d.success) {
        tr.querySelector('.d-planned').textContent = d.planned_mh.toFixed(2);
      }
    });
  }, 500);
}
</script>

<div class="card" style="margin-top:16px">
  <div class="card-header"><h3>+ Add Custom Item</h3></div>
  <div style="padding:12px">
    <form action="/planning/<%= project.id %>/add-item" method="POST">
      <input type="hidden" name="scope_ref" value="<%= scopeRef %>">
      <div class="form-row">
        <div class="form-group"><label>Work Item *</label><input name="work_item" required></div>
        <div class="form-group"><label>Qty</label><input type="number" name="quantity" value="0" step="0.1"></div>
        <div class="form-group"><label>Unit</label><input name="unit" value="EA"></div>
        <div class="form-group"><label>Difficulty</label>
          <select name="difficulty"><option>Low</option><option selected>Normal</option><option>Difficult</option><option>N/A</option></select>
        </div>
        <div class="form-group"><label>Std MH/Unit</label><input type="number" name="std_mh_per_unit" value="1" step="0.1"></div>
      </div>
      <button type="submit" class="btn btn-teal btn-sm">Add Item</button>
    </form>
  </div>
</div>
<% } %>

<% } %>
<%- include('partials/footer') %>